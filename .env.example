# Mapbox — for vector map tiles + place autocomplete
# Get a free token at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Tankerkönig — for Germany real-time fuel prices
# Get a free key at https://creativecommons.tankerkoenig.de/
VITE_TANKERKOENIG_KEY=your_tankerkoenig_key_here

# Italy — Cloudflare Worker proxy for MIMIT open data
VITE_ITALY_WORKER_URL=https://your-italy-worker.workers.dev

# UK — Cloudflare Worker proxy for CMA retailer feeds
VITE_UK_WORKER_URL=https://your-uk-worker.workers.dev

# Switzerland — Cloudflare Worker proxy for Comparis/Navisano fuel prices
VITE_SWITZERLAND_PROXY_URL=https://your-switzerland-worker.workers.dev
