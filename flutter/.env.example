# Switzerland proxy URL (optional, falls back to demo)
SWITZERLAND_PROXY_URL=

# USA fuel data via proxy/worker (optional, falls back to demo)
USA_WORKER_URL=

# Canada fuel data via proxy/worker (optional, falls back to demo)
CANADA_WORKER_URL=

# Google Maps API key (required for map display)
GOOGLE_MAPS_API_KEY=
